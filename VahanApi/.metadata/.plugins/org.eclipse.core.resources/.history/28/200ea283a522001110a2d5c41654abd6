package com.vahan;

import java.io.*;
import java.net.HttpURLConnection;
import java.net.URL;
import java.nio.charset.StandardCharsets;

import org.apache.poi.ss.usermodel.*;
import org.apache.poi.xssf.usermodel.XSSFWorkbook;
import org.json.JSONArray;
import org.json.JSONObject;

public class VahanExcelProcessor {

    public static void main(String[] args) {

        String inputFile = "D:/vehicle_input.xlsx";
        String outputFile = "D:/vehicle_output.xlsx";

        try {

            // STEP 1: Get Token ONCE
            String token = getToken();
            System.out.println("Token: " + token);

            // STEP 2: Read Excel
            FileInputStream fis = new FileInputStream(inputFile);
            Workbook workbook = new XSSFWorkbook(fis);
            Sheet sheet = workbook.getSheetAt(0);

            // Output workbook
            Workbook outWorkbook = new XSSFWorkbook();
            Sheet outSheet = outWorkbook.createSheet("Response");

            // Header
            Row header = outSheet.createRow(0);
            header.createCell(0).setCellValue("Vehicle No");
            header.createCell(1).setCellValue("Response JSON");

            int lastRow = sheet.getLastRowNum();

            for (int i = 1; i <= lastRow; i++) {

                Row row = sheet.getRow(i);
                if (row == null) continue;

                Cell cell = row.getCell(0);
                if (cell == null) continue;

                String vehicleNo = cell.getStringCellValue().trim();

                System.out.println("Processing: " + vehicleNo);

                String responseJson;

                try {
                    responseJson = getVehicleDetails(token, vehicleNo);
                } catch (Exception e) {
                    responseJson = "{\"status\":\"ERROR\",\"message\":\"" + e.getMessage() + "\"}";
                }

                // Write to output
                Row outRow = outSheet.createRow(i);
                outRow.createCell(0).setCellValue(vehicleNo);
                outRow.createCell(1).setCellValue(responseJson);

                // Small delay to avoid API blocking
                Thread.sleep(500);
            }

            // Auto-size columns
            outSheet.autoSizeColumn(0);
            outSheet.autoSizeColumn(1);

            // Write file
            FileOutputStream fos = new FileOutputStream(outputFile);
            outWorkbook.write(fos);

            fos.close();
            workbook.close();

            System.out.println("✅ Done! Output saved at: " + outputFile);

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // ================= TOKEN API =================
    public static String getToken() throws Exception {

        String urlString = "https://api-platform.mastersindia.co/api/v1/token-auth/";
        String jsonBody = "{\"username\":\"aayogagro@gmail.com\",\"password\":\"AAag12@@@$$$\"}";

        URL url = new URL(urlString);
        HttpURLConnection conn = (HttpURLConnection) url.openConnection();

        conn.setRequestMethod("POST");
        conn.setDoOutput(true);

        conn.setRequestProperty("Content-Type", "application/json");
        conn.setRequestProperty("Accept", "application/json");

        try (OutputStream os = conn.getOutputStream()) {
            os.write(jsonBody.getBytes(StandardCharsets.UTF_8));
        }

        BufferedReader br = new BufferedReader(
                new InputStreamReader(conn.getInputStream(), StandardCharsets.UTF_8));

        StringBuilder response = new StringBuilder();
        String line;

        while ((line = br.readLine()) != null) {
            response.append(line.trim());
        }

        JSONObject json = new JSONObject(response.toString());

        conn.disconnect();

        return json.getString("token");
    }

    // ================= VEHICLE API =================
    public static String getVehicleDetails(String token, String vehicleNo) {

        try {

            String urlString = "https://api-platform.mastersindia.co/api/v1/vahan/vehicle-details/";
            String jsonBody = "{\"vehicle_number\":\"" + vehicleNo + "\"}";

            URL url = new URL(urlString);
            HttpURLConnection conn = (HttpURLConnection) url.openConnection();

            conn.setRequestMethod("POST");
            conn.setDoOutput(true);

            conn.setRequestProperty("Authorization", "JWT " + token);
            conn.setRequestProperty("Content-Type", "application/json");

            try (OutputStream os = conn.getOutputStream()) {
                os.write(jsonBody.getBytes(StandardCharsets.UTF_8));
            }

            BufferedReader br = new BufferedReader(
                    new InputStreamReader(conn.getInputStream(), StandardCharsets.UTF_8));

            StringBuilder response = new StringBuilder();
            String line;

            while ((line = br.readLine()) != null) {
                response.append(line.trim());
            }

            conn.disconnect();

            // Parse JSON response
            JSONObject vahanJson = new JSONObject(response.toString());

            JSONObject dataObj = vahanJson.getJSONObject("data");
            JSONArray respArr = dataObj.getJSONArray("response");
            JSONObject first = respArr.getJSONObject(0);

            String xmlString = first.getString("response");

            // If not XML → return message
            if (xmlString == null || !xmlString.trim().startsWith("<")) {
                JSONObject error = new JSONObject();
                error.put("status", "NOT FOUND");
                error.put("message", xmlString);
                return error.toString();
            }

            // Otherwise return full JSON
            return vahanJson.toString();

        } catch (Exception e) {
            return "{\"status\":\"ERROR\",\"message\":\"" + e.getMessage() + "\"}";
        }
    }
}
